# ABC Grok Trader — Environment Configuration
# Copy to .env and fill in your values: cp .env.template .env

# ===========================================
# IBKR CONNECTION (Required)
# ===========================================
IBKR_HOST=127.0.0.1
IBKR_PORT=7497           # 7497=paper (default), 7496=live
IBKR_CLIENT_ID=1          # Must be unique per simultaneous TWS/API connection (agent + scripts)
IBKR_CONNECT_MAX_ATTEMPTS=12  # On connect, try CLIENT_ID .. CLIENT_ID+N-1 (max 50) until one is free
IBKR_ACCOUNT_ID=DUF123456  # Your paper account ID (starts with DU)

# ===========================================
# GROK API (Required)
# ===========================================
GROK_API_KEY=your_grok_api_key_here
# Alternative: XAI_API_KEY=your_xai_api_key_here

# ===========================================
# TRADING MODE
# ===========================================
TRADING_MODE=paper       # aggressive_paper | paper | live
                         #   aggressive_paper — stress test: 5% risk, 1.5:1 R:R, forces complex options
                         #   paper            — normal paper trading: 1% risk, 2:1 R:R (default)
                         #   live             — real money: 1% risk, 2.5:1 R:R, port 7496
TOOL_SMOKE_MODE=0        # 1 = prompt forces broad real-tool smoke protocol (paper only)
PAPER_MODE=True          # Legacy safety toggle (True=paper). TRADING_MODE takes priority when set.

# ===========================================
# LLM / MULTI-AGENT COST GUARDS (xAI spend)
# ===========================================
# MAX_DAILY_LLM_COST is enforced in the agent loop (tracked USD from token estimates; halt when reached).
MAX_DAILY_LLM_COST=4.5                   # default under a ~$5 prepaid top-up; increase in .env when ready
# research() uses a separate sub-cap persisted in research_config (multi_agent_llm_* keys):
MAX_DAILY_MULTI_AGENT_RESEARCH_USD=0.75  # one multi-agent call can burn this fast — keep low
MULTI_AGENT_RESEARCH_ENABLED=1           # 0 = research() tool returns error immediately
# First trading-day pre-scan: 0 = cheap tools first (default); 1 = legacy prompt that nudges research()
PRESCAN_PROMPT_EXPENSIVE_RESEARCH=0
# Reasoning Grok re-sends the full ReAct thread each turn — cap playbook + tool JSON feedback:
TOOL_PLAYBOOK_MAX_CHARS=1200             # passed to render_compact_playbook
AGENT_TOOL_FEEDBACK_MAX_CHARS=4500      # max chars per tool result appended to chat (truncate rest)

# Daily xAI token ceilings (hard halt — see data.cost_tracker.CostTracker.check_daily_token_limits)
MAX_DAILY_LLM_NONCACHED_PROMPT_TEXT_TOKENS=350000
MAX_DAILY_LLM_CACHED_PROMPT_TEXT_TOKENS=999999999
MAX_DAILY_LLM_PROMPT_IMAGE_TOKENS=50000
MAX_DAILY_LLM_COMPLETION_TOKENS=80000
MAX_DAILY_LLM_REASONING_TOKENS=120000
MAX_DAILY_LLM_OUTPUT_PRICED_TOKENS=150000

# ===========================================
# MARKET DATA (Optional — for real-time quotes)
# ===========================================
# MARKETDATA_TOKEN=your_marketdata_api_key_here
# (Token only — do not prefix with "Bearer ".) MarketData.app allows one active egress IP
# per account; same token on research host + trader simultaneously → HTTP 403 multi-IP block.
# Fix: one machine calls MDA, or separate accounts/tokens, or pause one side 5+ minutes when switching.
# MDA_INTRADAY_EXTENDED=1   # set on research host: include extended-hours intraday candles (more bars, more credits)

# ===========================================
# RISK SETTINGS (CASH-ONLY — no margin ever)
# ===========================================
RISK_PER_TRADE=1.0   # % of CASH balance per trade (1.0 = 1%). Change to 0.5 for ultra-conservative or 2.0 for testing
CASH_ONLY=true       # Enforce cash-only — no short selling, no margin

# ===========================================
# OPTIONAL
# ===========================================
LOG_LEVEL=INFO
SKIP_HEAVY_UTILS_IMPORTS=true

# ===========================================
# TRADER vs RESEARCH DAEMON (split host)
# ===========================================
# auto (default) = start in-process scorer only if research_daemon heartbeat is stale.
# never = never start scorer in trader; exit at boot if heartbeat not fresh (like --require-daemon).
#         research_engine tool cannot start/resume scorer. Override dev: python __main__.py --force-in-process
# TRADER_IN_PROCESS_SCORER=never

# ===========================================
# DATABASE (Required - PostgreSQL)
# ===========================================
# Preferred single-DSN format:
# DATABASE_URL=postgresql://research_user:your_password@127.0.0.1:5432/abc_shared
#
# Or equivalent split vars:
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=abc_shared
# PGUSER=research_user
# PGPASSWORD=your_password
#
# Shared schema owner for DDL (CREATE INDEX in init_db) on BOTH research and trader.
# Required on existing DBs after: infra/postgres/admin/reassign_owned_to_abc_app.sql
# DATABASE_APP_ROLE=abc_app
