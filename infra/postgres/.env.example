# Copy this file to .env and set strong passwords.
# This .env is consumed only by infra/postgres/docker-compose.yml.

POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASS=CHANGE_ME_SUPERUSER_PASSWORD
