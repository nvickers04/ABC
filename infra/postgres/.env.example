APP_RESEARCH_USER=research_user
APP_RESEARCH_PASSWORD=CHANGE_ME_RESEARCH_PASSWORD

APP_TRADER_USER=trader_user
APP_TRADER_PASSWORD=CHANGE_ME_TRADER_PASSWORD
