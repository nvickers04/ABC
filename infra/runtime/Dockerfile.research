# Research-only image: runs signals/scorer cadence + optional template evolution.
# Does NOT run __main__.py (trader / Grok agent loop).
FROM python:3.11-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

COPY . .

# research_daemon.py disables IBKR quote routing internally; no TWS in this container.
CMD ["python", "research_daemon.py"]
