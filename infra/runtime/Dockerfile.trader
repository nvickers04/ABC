# Trader image: Grok ReAct agent (__main__.py) with IBKR + LLM.
# Requires host TWS/Gateway (paper 7497 / live 7496) via host.docker.internal.
FROM python:3.11-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    TRADER_IN_PROCESS_SCORER=never \
    DOCKER_HEALTHCHECK_REQUIRE_RESEARCH=0

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

COPY . .

# Override in compose: prod uses --require-research-host; dev uses --verbose only.
CMD ["python", "__main__.py", "--require-research-host", "--verbose"]

HEALTHCHECK --interval=60s --timeout=20s --start-period=60s --retries=3 \
    CMD ["python", "scripts/docker_healthcheck.py", "trader"]
