# Research-host .env template — copy values into repo root .env on the research machine.
# Never run __main__.py on this host.

DATABASE_URL=postgresql://research_user:CHANGE_ME@abc-postgres:5432/abc_shared

ABC_RESEARCH_HOST=1
IBKR_QUOTES_ENABLED=0
RESEARCHER_DAILY_TOKEN_CAP=100000

# MarketData.app (required for research host startup health)
MARKETDATA_API_KEY=CHANGE_ME

# Optional: status stack on research box
ABC_HEALTH_ROLE=researcher
STATUS_API_PORT=8790
DASHBOARD_PASSWORD=
