# Trader-host .env template — copy values into repo root .env on the trader machine.
# Never run python -m research on this host.

DATABASE_URL=postgresql://trader_user:CHANGE_ME@YOUR_POSTGRES_HOST:5432/abc_shared

# xAI / Grok (required for trader)
XAI_API_KEY=CHANGE_ME

# IBKR via host TWS/Gateway (Docker uses host.docker.internal)
IBKR_HOST=host.docker.internal
IBKR_CLIENT_ID=11

# Production split-host (also set by deploy profile + prod compose override)
TRADER_IN_PROCESS_SCORER=never
DOCKER_HEALTHCHECK_REQUIRE_RESEARCH=1

# Profile: paper vs live (deploy.py --env paper|live loads infra/runtime/env/*.env)
TRADING_MODE=paper
IBKR_ACCOUNT_TYPE=paper
IBKR_PORT=7497
PROFIT_PROFILE=balanced

# Optional observability
ABC_HEALTH_ROLE=trader
STATUS_API_PORT=8790
DASHBOARD_PASSWORD=
ALERT_WEBHOOK_URL=
