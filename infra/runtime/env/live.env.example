# Live trading profile — merge into repo .env before production deploy.
# Used by: python infra/deploy.py --env live --role trader
#
# Copy to infra/runtime/env/live.env for local overrides (gitignored).

TRADING_MODE=live
IBKR_ACCOUNT_TYPE=live
IBKR_PORT=7496
PAPER_MODE=0
PROFIT_PROFILE=balanced

TRADER_IN_PROCESS_SCORER=never
DOCKER_HEALTHCHECK_REQUIRE_RESEARCH=1
