# Paper trading profile — merge into repo .env (secrets stay in .env).
# Used by: python infra/deploy.py --env paper --role trader|research|all
#
# Copy to infra/runtime/env/paper.env for local overrides (gitignored).

TRADING_MODE=paper
IBKR_ACCOUNT_TYPE=paper
IBKR_PORT=7497
PAPER_MODE=1
PROFIT_PROFILE=balanced

# Split-host production trader (compose prod override also sets these)
TRADER_IN_PROCESS_SCORER=never
DOCKER_HEALTHCHECK_REQUIRE_RESEARCH=1
